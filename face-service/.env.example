# Địa chỉ gốc của ứng dụng Laravel (không kèm dấu / cuối)
LARAVEL_BASE_URL=http://localhost

# Token bí mật, phải trùng với FACE_KIOSK_TOKEN trong .env của Laravel
FACE_KIOSK_TOKEN=doi-thanh-chuoi-bi-mat-cua-ban

# InsightFace
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=320
# Danh sách provider onnxruntime, phân tách bằng dấu phẩy
FACE_PROVIDERS=CPUExecutionProvider

# Camera
FACE_CAMERA_INDEX=0

# Ngưỡng cosine để coi là cùng một người (0..1, càng cao càng chặt)
FACE_COSINE_THRESHOLD=0.35
# Bỏ qua khuôn mặt có điểm phát hiện thấp hơn ngưỡng này
FACE_MIN_DET_SCORE=0.5

# Chu kỳ đồng bộ lại thư viện khuôn mặt (giây)
FACE_SYNC_INTERVAL=120
# Thời gian chờ tối thiểu giữa 2 lần chấm công của cùng một người (giây)
FACE_COOLDOWN_SECONDS=30

# Chống giả mạo (liveness) - chống ảnh in / màn hình
FACE_LIVENESS_ENABLED=true
FACE_LIVENESS_THRESHOLD=0.5
# Thư mục chứa model MiniFASNet (.onnx). Bỏ trống model = dùng heuristic dự phòng.
FACE_LIVENESS_MODEL_DIR=

# Chống video giả (liveness chủ động: yêu cầu quay đầu trái/phải)
FACE_ACTIVE_LIVENESS_ENABLED=false
# Cửa sổ thời gian để thực hiện quay đầu (giây)
FACE_ACTIVE_WINDOW_SECONDS=6
# Biên độ thay đổi góc quay tối thiểu để xác nhận là người thật
FACE_YAW_DELTA=0.35

# Timeout cho request HTTP (giây)
FACE_REQUEST_TIMEOUT=15

# Cổng HTTP API phục vụ quét mặt trên trang web (api_server.py)
FACE_API_PORT=5555
